<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PowerFit Gym</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:#f4f4f4;
      color:#333;
      text-align:center;
    }

    /* HERO SECTION */
    .hero{
      background:linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
      url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=1200&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
      color:white;
      padding:100px 20px;
    }

    .hero h1{
      font-size:50px;
      margin-bottom:15px;
    }

    .hero p{
      font-size:20px;
      margin-bottom:25px;
    }

    .btn{
      display:inline-block;
      background:#ff3c00;
      color:white;
      padding:14px 30px;
      border-radius:8px;
      text-decoration:none;
      font-size:18px;
      transition:0.3s;
    }

    .btn:hover{
      background:#d62f00;
    }

    /* SECTION */
    section{
      padding:60px 20px;
    }

    h2{
      margin-bottom:25px;
      font-size:35px;
      color:#111;
    }

    /* FEATURES */
    .features{
      display:flex;
      flex-wrap:wrap;
      justify-content:center;
      gap:20px;
      margin-top:30px;
    }

    .card{
      background:white;
      width:280px;
      padding:25px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    .card h3{
      margin-bottom:15px;
      color:#ff3c00;
    }

    /* PRICING */
    .pricing{
      display:flex;
      flex-wrap:wrap;
      justify-content:center;
      gap:20px;
      margin-top:30px;
    }

    .price-card{
      background:white;
      width:280px;
      padding:30px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    .price-card h3{
      color:#ff3c00;
      margin-bottom:10px;
    }

    .price{
      font-size:40px;
      margin:20px 0;
      font-weight:bold;
    }

    /* TESTIMONIALS */
    .testimonials{
      display:flex;
      flex-wrap:wrap;
      justify-content:center;
      gap:20px;
      margin-top:30px;
    }

    .testimonial{
      background:white;
      width:300px;
      padding:20px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    /* CONTACT */
    .contact-box{
      background:white;
      max-width:500px;
      margin:auto;
      padding:30px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    input{
      width:100%;
      padding:14px;
      margin:10px 0;
      border-radius:8px;
      border:1px solid #ccc;
      font-size:16px;
    }

    /* FOOTER */
    footer{
      background:#111;
      color:white;
      padding:20px;
      margin-top:40px;
    }

    /* WHATSAPP BUTTON */
    .whatsapp{
      position:fixed;
      bottom:20px;
      right:20px;
      background:#25D366;
      color:white;
      padding:15px 18px;
      border-radius:50%;
      text-decoration:none;
      font-size:22px;
      box-shadow:0 4px 8px rgba(0,0,0,0.3);
    }

  </style>
</head>

<body>

  <!-- HERO -->
  <div class="hero">
    <h1>PowerFit Gym</h1>
    <p>Transform Your Body. Transform Your Life 💪</p>

    <a href="#join" class="btn">Join Now</a>
  </div>

  <!-- FEATURES -->
  <section>
    <h2>Why Choose Us</h2>

    <div class="features">

      <div class="card">
        <h3>Modern Equipment</h3>
        <p>Train with advanced gym machines and equipment.</p>
      </div>

      <div class="card">
        <h3>Expert Trainers</h3>
        <p>Professional trainers to guide your fitness journey.</p>
      </div>

      <div class="card">
        <h3>Weight Loss Programs</h3>
        <p>Special plans for fat loss and body transformation.</p>
      </div>

      <div class="card">
        <h3>Muscle Building</h3>
        <p>Gain strength and build muscle effectively.</p>
      </div>

    </div>
  </section>

  <!-- PRICING -->
  <section style="background:#fff;">
    <h2>Membership Plans</h2>

    <div class="pricing">

      <div class="price-card">
        <h3>Basic</h3>
        <div class="price">₹999</div>

        <p>✔ Gym Access</p>
        <p>✔ Cardio Area</p>
        <p>✔ Locker Facility</p>
      </div>

      <div class="price-card" style="border:2px solid #ff3c00;">
        <h3>Standard</h3>
        <div class="price">₹1999</div>

        <p>✔ Full Gym Access</p>
        <p>✔ Personal Guidance</p>
        <p>✔ Diet Tips</p>
      </div>

      <div class="price-card">
        <h3>Premium</h3>
        <div class="price">₹2999</div>

        <p>✔ Personal Trainer</p>
        <p>✔ Custom Workout Plan</p>
        <p>✔ Nutrition Guidance</p>
      </div>

    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section>
    <h2>What Members Say</h2>

    <div class="testimonials">

      <div class="testimonial">
        <p>"Amazing gym with great trainers!"</p>
        <strong>- Rahul</strong>
      </div>

      <div class="testimonial">
        <p>"Lost 8kg in 2 months. Highly recommended."</p>
        <strong>- Aman</strong>
      </div>

      <div class="testimonial">
        <p>"Best gym environment and modern equipment."</p>
        <strong>- Rohit</strong>
      </div>

    </div>
  </section>

  <!-- CONTACT -->
  <section id="join">
    <h2>Join Today</h2>

    <div class="contact-box">

      <input type="text" placeholder="Your Name">
      <input type="tel" placeholder="Phone Number">
      <input type="email" placeholder="Your Email">

      <a href="https://wa.me/919999999999" class="btn">
        Contact on WhatsApp
      </a>

    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 PowerFit Gym. All Rights Reserved.</p>
  </footer>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/919999999999"
     class="whatsapp">
     💬
  </a>

</body>
</html>
